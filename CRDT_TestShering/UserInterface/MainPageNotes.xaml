<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CRDT_TestShering.UserInterface.MainPageNotes"
             Title="My Notes">
    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="10" RowSpacing="10">
        <!-- Header with Title and Login Button -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,10,0,20">
            <Label 
                Grid.Column="0"
                Text="My Notes"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                VerticalOptions="Center" />

            <Button 
                x:Name="LoginButton"
                Grid.Column="1"
                Text="Login"
                BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="8"
                FontSize="14"
                HeightRequest="40"
                WidthRequest="80"
                Clicked="OnLoginClicked" />
        </Grid>

        <Button 
            Grid.Row="1"
            Text="+ Create New Note"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="8"
            FontSize="16"
            FontAttributes="Bold"
            HeightRequest="50"
            Margin="0,0,0,10"
            Clicked="OnCreateNoteClicked" />

        <CollectionView 
            Grid.Row="3"
            ItemsSource="{Binding ListOfNotes}"
            SelectionMode="Single">
            <CollectionView.EmptyView>
                <Label Text="No notes found. Add some notes to get started!"
                       FontSize="16"
                       TextColor="Gray"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="20"/>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" 
                           Padding="10" 
                           BorderColor="LightGray"
                           CornerRadius="8"
                           HasShadow="True">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding Title}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="Black"/>
                            <Label Text="{Binding Content}"
                                   FontSize="14"
                                   TextColor="DarkGray"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation"/>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding StartingDate, StringFormat='Created: {0}'}"
                                       FontSize="12"
                                       TextColor="Gray"/>
                                <Label Text="{Binding lastUpdate, StringFormat='Updated: {0}'}"
                                       FontSize="12"
                                       TextColor="Gray"/>
                            </HorizontalStackLayout>
                            <Button 
                                Text="Open Note"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                CornerRadius="8"
                                FontSize="14"
                                HeightRequest="40"
                                Margin="0,10,0,0"
                                Clicked="OnOpenNoteClicked"
                                CommandParameter="{Binding .}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>