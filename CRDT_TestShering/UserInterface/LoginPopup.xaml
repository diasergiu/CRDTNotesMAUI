<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CRDT_TestShering.UserInterface.LoginPopup"
             BackgroundColor="#80000000">

    <!-- Semi-transparent overlay with centered login box -->
    <Grid VerticalOptions="Center" HorizontalOptions="Center">
        <Frame BackgroundColor="White"
               CornerRadius="10"
               Padding="30"
               HasShadow="True"
               WidthRequest="350"
               MaximumWidthRequest="400">

            <VerticalStackLayout Spacing="20">
                <!-- Header -->
                <Label Text="Login to Server"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black" />

                <!-- Username Entry -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Username"
                           FontSize="14"
                           TextColor="#333" />
                    <Entry x:Name="UsernameEntry"
                           Placeholder="Enter username"
                           FontSize="16"
                           BackgroundColor="#F5F5F5"
                           TextColor="Black" />
                </VerticalStackLayout>

                <!-- Password Entry -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Password"
                           FontSize="14"
                           TextColor="#333" />
                    <Entry x:Name="PasswordEntry"
                           Placeholder="Enter password"
                           IsPassword="True"
                           FontSize="16"
                           BackgroundColor="#F5F5F5"
                           TextColor="Black" />
                </VerticalStackLayout>

                <!-- Status Label -->
                <Label x:Name="StatusLabel"
                       FontSize="14"
                       TextColor="Red"
                       HorizontalOptions="Center"
                       IsVisible="False" />

                <!-- Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            BackgroundColor="#9E9E9E"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="50"
                            Clicked="OnCancelClicked" />

                    <Button Grid.Column="1"
                            x:Name="LoginSubmitButton"
                            Text="Login"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="50"
                            Clicked="OnLoginSubmitClicked" />
                </Grid>

                <!-- Create Account Link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                    <Label Text="Don't have an account?"
                           FontSize="14"
                           TextColor="#666" />
                    <Label Text="Create one"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#2196F3"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCreateAccountTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
