<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CRDT_TestShering.UserInterface.NoteView"
             Title="Edit Note">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label 
                Text="Edit Note"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Margin="0,10,0,20" />

            <Label 
                Text="Title"
                FontSize="16"
                FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Entry 
                    x:Name="TitleEntry"
                    Grid.Column="0"
                    Placeholder="Enter note title..."
                    FontSize="16"
                    TextChanged="OnTitleTextChanged" />
                <Image 
                    x:Name="WarningIcon"
                    Grid.Column="1"
                    Source="warning.png"
                    WidthRequest="24"
                    HeightRequest="24"
                    IsVisible="False"
                    VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnWarningIconTapped" />
                    </Image.GestureRecognizers>
                </Image>
            </Grid>

            <Label 
                Text="Content"
                FontSize="16"
                FontAttributes="Bold" />
            <Editor 
                x:Name="ContentEditor"
                Placeholder="Enter note content..."
                FontSize="14"
                MinimumHeightRequest="300"
                AutoSize="TextChanges"
                Margin="0,0,0,20" />

            <Button 
                x:Name="SaveButton"
                Text="Save Note"
                BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="8"
                HeightRequest="50"
                FontSize="16"
                FontAttributes="Bold"
                Clicked="OnSaveClicked"
                Margin="0,10,0,0" />

            <Button 
                x:Name="CancelButton"
                Text="Cancel"
                BackgroundColor="#9E9E9E"
                TextColor="White"
                CornerRadius="8"
                HeightRequest="50"
                FontSize="16"
                Clicked="OnCancelClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>