<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CRDT_TestShering.UserInterface.MainPageNotes"
             Title="My Notes">
    <VerticalStackLayout Padding="10" Spacing="10">
        <Label 
            Text="My Notes"
            FontSize="24"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            Margin="0,10,0,20" />

        <CollectionView ItemsSource="{Binding ListOfNotes}"
                        SelectionMode="Single">
            <CollectionView.EmptyView>
                <Label Text="No notes found. Add some notes to get started!"
                       FontSize="16"
                       TextColor="Gray"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="20"/>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" 
                           Padding="10" 
                           BorderColor="LightGray"
                           CornerRadius="8"
                           HasShadow="True">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding Title}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="Black"/>
                            <Label Text="{Binding Content}"
                                   FontSize="14"
                                   TextColor="DarkGray"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation"/>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding StartingDate, StringFormat='Created: {0}'}"
                                       FontSize="12"
                                       TextColor="Gray"/>
                                <Label Text="{Binding lastUpdate, StringFormat='Updated: {0}'}"
                                       FontSize="12"
                                       TextColor="Gray"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage></ContentPage>